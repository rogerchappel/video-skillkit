{
  "name": "video-skillkit",
  "version": "0.1.0",
  "description": "Local-first agent skill for grounded product video briefs and production manifests.",
  "type": "module",
  "bin": {
    "video-skillkit": "./bin/video-skillkit.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js && node --check bin/video-skillkit.js",
    "smoke": "node bin/video-skillkit.js brief fixtures/product-repo --out .tmp/smoke && node bin/video-skillkit.js validate .tmp/smoke/video.json",
    "build": "npm run check",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "video",
    "pre-production",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/video-skillkit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/video-skillkit/issues"
  },
  "homepage": "https://github.com/rogerchappel/video-skillkit#readme",
  "author": "Roger Chappel"
}
